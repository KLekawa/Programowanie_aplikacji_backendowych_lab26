@WebApi_HostAddress = http://localhost:5154

### Wyświetlanie kontaków - błędne (brak query)
GET {{WebApi_HostAddress}}/api/contacts
Accept: application/json


### Wyświetlanie kontaków - poprawne
GET {{WebApi_HostAddress}}/api/contacts?page=1&size=4
Accept: application/json


### Wyświetlanie osoby - poprawne
GET {{WebApi_HostAddress}}/api/contacts/adc15ac1-7e05-47c4-9049-c6c89e7b8f9c
Accept: application/json


### Dodanie osoby - poprawne
POST {{WebApi_HostAddress}}/api/contacts
Content-Type: application/json

{
  "firstName": "Grzegorz",
  "lastName" : "Nowinski",
  "Email": "grzegorz@wsei.edu.pl",
  "phone": "+48123456789"
}


### Dodanie osoby - brak email i phone
POST {{WebApi_HostAddress}}/api/contacts
Content-Type: application/json

{
  "firstName": "Adam",
  "lastName" : "Nowak"
}


### Update osoby - poprawny
PUT {{WebApi_HostAddress}}/api/contacts/adc15ac1-7e05-47c4-9049-c6c89e7b8f9c
Content-Type: application/json

{
  "firstName": "Monika",
  "lastName": "Kowalska",
  "email" : null,
  "position" : "Intern"
}
 


### Dodanie notatki - poprawne
POST {{WebApi_HostAddress}}/api/contacts/adc15ac1-7e05-47c4-9049-c6c89e7b8f9c/notes
Content-Type: application/json

{
  "content": "New note"
}

